{
  "name": "eq-theory-crafting",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @eq/web dev",
    "dev:server": "pnpm --filter @eq/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter @eq/server db:push",
    "db:seed": "pnpm --filter @eq/server db:seed"
  }
}
