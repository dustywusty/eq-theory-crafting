{
  "name": "@eq/server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@eq/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@neondatabase/serverless": "^0.10.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
